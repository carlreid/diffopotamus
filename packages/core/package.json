{
  "name": "@diffopotamus/core",
  "version": "1.0.1",
  "description": "Core functionality for diffopotamus",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    },
    "./styles": "./dist/esm/index.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build.js && tsc --emitDeclarationOnly",
    "dev": "tsc --watch"
  },
  "keywords": [
    "diff",
    "comparison"
  ],
  "author": "Carl Reid",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlreid/diffopotamus.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "wyw-in-js": {
    "evaluate": true,
    "displayName": false,
    "classNameSlug": "[hash]"
  },
  "devDependencies": {
    "@linaria/core": "^6.3.0",
    "@wyw-in-js/esbuild": "^0.7.0"
  }
}
