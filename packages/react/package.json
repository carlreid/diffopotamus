{
  "name": "@diffopotamus/react",
  "version": "1.0.1",
  "description": "React components for diffopotamus",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.js && tsc --emitDeclarationOnly",
    "dev": "tsc --watch"
  },
  "keywords": [
    "diff",
    "comparison",
    "react"
  ],
  "author": "Carl Reid",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlreid/diffopotamus.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@diffopotamus/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.12"
  }
}
